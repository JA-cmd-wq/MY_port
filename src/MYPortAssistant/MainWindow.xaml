<Window x:Class="MYPortAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MY Port Assistant" Height="720" MinHeight="640" Width="1080" MinWidth="960"
        Background="#F3F6FA" FontFamily="Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Background="#FFFFFF" BorderBrush="#DDE3EA" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="MY Port Assistant" FontSize="24" FontWeight="SemiBold" Foreground="#172033" />
                    <TextBlock Text="面向嵌入式调试的 Windows 串口助手" Margin="0,6,0,0" Foreground="#667085" />
                </StackPanel>

                <TextBlock x:Name="ConnectionStateTextBlock" Grid.Column="1" Text="未连接" Foreground="#B42318"
                           VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" Background="#FFFFFF" BorderBrush="#DDE3EA" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="串口配置" FontSize="18" FontWeight="SemiBold" Foreground="#172033" />

                    <TextBlock Text="串口" Margin="0,18,0,6" Foreground="#344054" />
                    <DockPanel>
                        <ComboBox x:Name="PortNameComboBox" MinHeight="34" DockPanel.Dock="Left" Width="176" />
                        <Button x:Name="RefreshPortsButton" Content="刷新" Margin="8,0,0,0" MinHeight="34" Click="RefreshPortsButton_Click" />
                    </DockPanel>

                    <TextBlock Text="波特率" Margin="0,14,0,6" Foreground="#344054" />
                    <ComboBox x:Name="BaudRateComboBox" MinHeight="34" />

                    <TextBlock Text="数据位" Margin="0,14,0,6" Foreground="#344054" />
                    <ComboBox x:Name="DataBitsComboBox" MinHeight="34" />

                    <TextBlock Text="停止位" Margin="0,14,0,6" Foreground="#344054" />
                    <ComboBox x:Name="StopBitsComboBox" MinHeight="34" />

                    <TextBlock Text="校验位" Margin="0,14,0,6" Foreground="#344054" />
                    <ComboBox x:Name="ParityComboBox" MinHeight="34" />

                    <Button x:Name="OpenPortButton" Content="打开串口" Margin="0,22,0,0" MinHeight="38"
                            Background="#175CD3" Foreground="#FFFFFF" BorderBrush="#175CD3" Click="OpenPortButton_Click" />
                    <Button x:Name="ClosePortButton" Content="关闭串口" Margin="0,10,0,0" MinHeight="38"
                            IsEnabled="False" Click="ClosePortButton_Click" />

                    <Separator Margin="0,22,0,18" />

                    <TextBlock Text="显示模式" FontSize="16" FontWeight="SemiBold" Foreground="#172033" />
                    <StackPanel Margin="0,10,0,0">
                        <RadioButton x:Name="AsciiDisplayRadioButton" Content="ASCII 显示" IsChecked="True" Checked="DisplayModeRadioButton_Checked" />
                        <RadioButton x:Name="HexDisplayRadioButton" Content="HEX 显示" Margin="0,8,0,0" Checked="DisplayModeRadioButton_Checked" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16" Background="#FFFFFF" BorderBrush="#DDE3EA" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock Text="接收区" FontSize="18" FontWeight="SemiBold" Foreground="#172033" DockPanel.Dock="Left" />
                            <Button x:Name="ClearReceiveButton" Content="清空接收区" MinHeight="32" Padding="12,0"
                                    HorizontalAlignment="Right" DockPanel.Dock="Right" Click="ClearReceiveButton_Click" />
                        </DockPanel>

                        <TextBox x:Name="ReceiveTextBox" Grid.Row="1" Margin="0,12,0,12" IsReadOnly="True"
                                 AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                 FontFamily="Consolas" FontSize="14" Background="#F8FAFC" BorderBrush="#D0D5DD" />

                        <TextBlock x:Name="ReceiveInfoTextBlock" Grid.Row="2" Text="接收字节：0" Foreground="#667085" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="16" Background="#FFFFFF" BorderBrush="#DDE3EA" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <TextBlock Text="发送区" FontSize="18" FontWeight="SemiBold" Foreground="#172033" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <RadioButton x:Name="TextSendRadioButton" Content="文本发送" IsChecked="True" VerticalAlignment="Center" />
                                <RadioButton x:Name="HexSendRadioButton" Content="HEX 发送" Margin="16,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>

                        <TextBox x:Name="SendTextBox" Grid.Row="1" Margin="0,12,0,12" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 FontFamily="Consolas" FontSize="14" Background="#F8FAFC" BorderBrush="#D0D5DD" />

                        <DockPanel Grid.Row="2">
                            <TextBlock x:Name="SendInfoTextBlock" Text="发送字节：0" Foreground="#667085" VerticalAlignment="Center" />
                            <Button x:Name="SendButton" Content="发送" MinWidth="120" MinHeight="36" HorizontalAlignment="Right"
                                    Background="#175CD3" Foreground="#FFFFFF" BorderBrush="#175CD3"
                                    IsEnabled="False" Click="SendButton_Click" />
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="12" Background="#FFFFFF" BorderBrush="#DDE3EA" BorderThickness="1" CornerRadius="8">
            <TextBlock x:Name="StatusTextBlock" Text="就绪" Foreground="#344054" />
        </Border>
    </Grid>
</Window>
